{
  "name": "claude-code-unspinner",
  "displayName": "Claude Code Unspinner",
  "description": "Enables changing spinnerVerbs for claude code the same way that the CLI app does.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "extensionDependencies": ["anthropic.claude-code"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Claude Code Unspinner",
      "properties": {
        "claude-code-unspinner.configMode": {
          "type": "string",
          "enum": ["vscodeSettings", "claudeCodeSettings", "off"],
          "enumDescriptions": ["Manage spinner verbs through VS Code settings", "Use Claude Code's native configuration of the current workspace", "Disable the extension"],
          "default": "vscodeSettings",
          "description": "Specifies the configuration mode for Claude Code Unspinner."
        },
        "claude-code-unspinner.originalSearchTerm": {
          "type": "string",
          "default": "Accomplishing",
          "description": "Specifies a term from the original spinner verbs to search for."
        },
        "claude-code-unspinner.spinnerVerbs": {
          "type": "object",
          "required": ["mode", "verbs"],
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["replace", "append"],
              "default": "replace"
            },
            "verbs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "test:unit": "npm run compile-tests && node node_modules/mocha/bin/mocha.js \"out/test/**/*.test.js\" --ui tdd"
  },
  "devDependencies": {
    "@types/vscode": "^1.116.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "eslint": "^9.34.0",
    "esbuild": "^0.25.9",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.2",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  }
}
